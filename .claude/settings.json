{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$raw = [Console]::In.ReadToEnd(); $data = $raw | ConvertFrom-Json; $cmd = $data.tool_input.command; $timestamp = Get-Date -Format 'yyyy-MM-dd HH:mm:ss'; Add-Content -Path '.claude/bash-log.txt' -Value \"[$timestamp] $cmd\" -Encoding utf8",
            "shell": "powershell",
            "async": true,
            "statusMessage": "Logging bash command..."
          },
          {
            "type": "command",
            "command": ".claude/hooks/guard-sql.ps1",
            "shell": "powershell",
            "statusMessage": "Checking for dangerous SQL..."
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/guard-appsettings.ps1",
            "shell": "powershell",
            "statusMessage": "Checking protected files..."
          }
        ]
      }
    ],
    "PostToolUse": [],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "Write-Output '{\"systemMessage\": \"Session complete! Run: git status to review changes before committing.\"}'",
            "shell": "powershell"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(sqlcmd *)",
      "Bash(dotnet *)",
      "Bash(New-Item *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(md *)",
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(dir)",
      "Bash(dir *)",
      "Bash(cd *)",
      "Bash(pwd)",
      "Bash(Get-ChildItem)",
      "Bash(Get-ChildItem *)",
      "Bash(Set-Location *)",
      "Bash(Get-Location)",
      "Bash(echo *)",
      "Bash(cat *)",
      "Bash(Get-Content *)",
      "Bash(Copy-Item *)",
      "Bash(Move-Item *)",
      "Bash(Remove-Item *)",
      "Bash(Rename-Item *)",
      "Bash(Test-Path *)",
      "Bash(Resolve-Path *)",
      "Bash(Select-String *)",
      "Bash(jq *)",
      "Bash(curl *)"
    ],
    "deny": []
  }
}
